{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "chula-powermap",
  "compatibility_date": "2026-07-01",
  // The actual Worker script. Without this, Cloudflare treats the project as
  // "static assets only" and there is nowhere to run our /api/* handlers or
  // add Secrets in the dashboard.
  "main": "src/index.js",
  "assets": {
    "directory": "./",
    "binding": "ASSETS",
    "not_found_handling": "404-page"
  },
  // Prevents future `wrangler deploy` runs (triggered automatically by every
  // git push) from wiping out the Secrets set via the Cloudflare dashboard
  // (ANTHROPIC_API_KEY, AIRTABLE_TOKEN, AIRTABLE_BASE_ID, AIRTABLE_TABLE_NAME).
  "keep_vars": true
  // Voice (Phase B) is disabled until R2 is enabled on the account.
  // To turn voice ON later: enable R2 in the Cloudflare dashboard (Storage & Databases
  // > R2 > Enable), then create the bucket:
  //   npx wrangler r2 bucket create chula-powermap-audio
  // and uncomment the two bindings below, then redeploy:
  // ,"r2_buckets": [ { "binding": "AUDIO_BUCKET", "bucket_name": "chula-powermap-audio" } ]
  // ,"ai": { "binding": "AI" }
}
